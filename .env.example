# Vercel Postgres auto-injects POSTGRES_URL when you add a Postgres database in the Vercel dashboard.
# For local dev, copy it from Vercel project > Storage > your DB > .env.local tab.
POSTGRES_URL="postgres://user:password@host.neon.tech/dbname?sslmode=require"

# Generate a strong random string: openssl rand -base64 32
JWT_SECRET="change-me-to-a-long-random-secret"

# Anything you want — used to protect the /api/admin/seed endpoint
ADMIN_SECRET="change-me-too"
